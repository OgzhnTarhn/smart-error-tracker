{
    "name": "@smart-error-tracker/browser",
    "version": "0.1.0",
    "description": "Browser SDK for Smart Error Tracker — automatic error capture & reporting",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.7.0"
    },
    "keywords": [
        "error-tracking",
        "sentry",
        "monitoring",
        "browser"
    ],
    "license": "MIT"
}