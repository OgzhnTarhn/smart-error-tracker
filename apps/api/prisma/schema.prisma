generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ErrorGroup {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  title       String
  count       Int      @default(0)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  sample      Json?

  events      Event[]
}

model Event {
  id        String   @id @default(cuid())
  groupId   String
  source    String
  message   String
  stack     String?
  context   Json?
  timestamp DateTime @default(now())

  group     ErrorGroup @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@index([timestamp])
}