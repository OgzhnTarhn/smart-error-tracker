generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ErrorGroup {
  id          String   @id @default(cuid())
  projectId   String
  fingerprint String
  title       String
  status      String   @default("open")
  resolutionNote String?
  isRegression   Boolean  @default(false)
  regressionCount Int     @default(0)
  lastRegressedAt DateTime?
  eventCount  Int      @default(0)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  sample      Json?
  aiAnalysis  Json? // Compatibility cache for the latest analyzed event payload

  project Project @relation(fields: [projectId], references: [id])
  events  Event[]

  @@unique([projectId, fingerprint])
  @@index([projectId])
}

model Event {
  id             String   @id @default(cuid())
  projectId      String
  groupId        String
  source         String
  message        String
  stack          String?
  context        Json?
  aiAnalysis     Json?
  environment    String?
  releaseVersion String?
  level          String?
  timestamp      DateTime @default(now())

  project Project    @relation(fields: [projectId], references: [id])
  group   ErrorGroup @relation(fields: [groupId], references: [id])

  @@index([projectId])
  @@index([groupId])
  @@index([timestamp])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  createdAt DateTime @default(now())

  apiKeys ApiKey[]
  groups  ErrorGroup[]
  events  Event[] // <-- BUNU EKLE
}

model ApiKey {
  id        String    @id @default(cuid())
  projectId String
  keyHash   String    @unique
  label     String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}
